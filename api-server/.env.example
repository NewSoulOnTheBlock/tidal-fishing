# CORS
CORS_ORIGIN=https://tidalfishing.fun

# Ban System (REQUIRED FOR ADMIN ENDPOINTS)
ADMIN_SECRET=your-strong-admin-password-here

# Account suspension (wallet ban enforcement). Off by default — set to true to
# re-enable enforcement of wallet bans set via the admin endpoints. IP bans and
# rate limiting are always active and unaffected by this flag.
ACCOUNT_SUSPENSION_ENABLED=false

# Server
NODE_ENV=production
PORT=3000

# ============================================================================
# 24-HOUR FISH RAFFLE -> GACHA PRIZE SYSTEM
# Players exchange caught fish for weighted raffle tickets; every 24h a winner is
# auto-selected, then an admin MANUALLY fulfills the Collector Crypt gacha NFT
# prize (the treasury pays USDC). The API key is server-side ONLY — never shipped
# to the browser.
# ============================================================================

# Collector Crypt Gacha API key (server-side only). Without it, raffles still run
# and pick winners, but fulfillment (the real-USDC pack purchase) is disabled.
GACHA_API_KEY=your_collector_crypt_api_key_here

# Gacha API base URL. Mainnet by default; use the devnet host for testing:
#   https://dev-gacha.collectorcrypt.com
GACHA_API_BASE=https://gacha.collectorcrypt.com

# Fallback prize pack used when the gacha /machines API is unreachable, so the
# cycle never stalls. Normally the cheapest pack of each card type is shuffled.
RAFFLE_DEFAULT_PACK=pokemon_50
RAFFLE_DEFAULT_PACK_NAME=Elite Pack
RAFFLE_DEFAULT_PACK_PRICE=50

# Raffle cycle length in hours (default 24).
RAFFLE_DURATION_HOURS=24

# Scheduler tick: how often (ms) the server checks for an expired raffle to draw.
# Min enforced 60000. Default 300000 (5 min).
RAFFLE_TICK_MS=300000

# When false (default), the scheduler only CHOOSES the winner automatically; an
# admin must POST /api/raffle/fulfill to spend USDC and deliver the NFT. Set true
# only if you want the scheduler to also execute the paid gacha purchase.
RAFFLE_AUTO_FULFILL=false

# USDC mint the treasury pays gacha packs from (mainnet USDC by default).
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
