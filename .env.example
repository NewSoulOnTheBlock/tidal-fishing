# Tidal — Web3 fishing on Solana mainnet
# Copy to .env.local for local dev. Set the same vars in Vercel project settings
# for production. All are optional in Phase 1; setting them unlocks features.

# Custom Solana RPC endpoint. Strongly recommended for production — the public
# api.mainnet-beta.solana.com endpoint is heavily rate-limited.
# Get a free key from Helius, QuickNode, Triton, or Alchemy.
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# $TIDE SPL token mint address (Phase 3 deployment).
# Until set, the wallet panel shows "—" for $TIDE balance and the
# "🔥 Burn $TIDE" gear/location buttons stay hidden.
# VITE_TIDE_MINT=

# Decimals of the $TIDE mint (default 9 to match SOL).
# VITE_TIDE_DECIMALS=9

# (Future) Bubblegum tree pubkey for catch cNFTs.
# VITE_CATCH_TREE=

# (Future) Verified-collection mint for gear NFTs.
# VITE_GEAR_COLLECTION=

# --- Server-only (no VITE_ prefix — never exposed to the client bundle) ---

# Treasury private key, base58 (Phantom: Settings → Show Private Key) OR a
# JSON byte array. This wallet signs every /api/withdraw transaction. Without
# it, /api/withdraw returns 503 "Withdrawals not configured".
# TIDAL_TREASURY_SECRET=

# Max $TIDE allowed per single /api/withdraw call. Defaults to 100,000,000.
# TIDAL_WITHDRAW_MAX=100000000
